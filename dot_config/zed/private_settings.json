{
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "auto_update": false,
  "restore_on_startup": "launchpad",
  "edit_predictions": {
    "provider": "zed"
  },
  "edit_predictions_disabled_in": ["comment"],
  "theme_overrides": {
    "Nord-Custom": {
      "players": [
        {
          "cursor": "#d8dee9cc"
        }
      ],
      "syntax": {
        "comment": {
          "font_style": "normal"
        },
        "comment.doc": {
          "font_style": "normal"
        },
        "constant.comment.todo": {
          "color": "#2E3440",
          "background_color": "#EBCB8B",
          "font_weight": 700
        },
        "constant.comment.todo.text": {
          "color": "#ECEFF4"
        },
        "property.comment.fixme": {
          "color": "#2E3440",
          "background_color": "#BF616A",
          "font_weight": 700
        },
        "property.comment.fixme.text": {
          "color": "#ECEFF4"
        },
        "property.comment.bug": {
          "color": "#2E3440",
          "background_color": "#BF616A",
          "font_weight": 700
        },
        "property.comment.bug.text": {
          "color": "#ECEFF4"
        },
        "property.comment.error": {
          "color": "#2E3440",
          "background_color": "#BF616A",
          "font_weight": 700
        },
        "property.comment.error.text": {
          "color": "#ECEFF4"
        },
        "keyword.comment.hack": {
          "color": "#2E3440",
          "background_color": "#D08770",
          "font_style": "italic",
          "font_weight": 700
        },
        "keyword.comment.hack.text": {
          "color": "#ECEFF4"
        },
        "keyword.comment.warn": {
          "color": "#2E3440",
          "background_color": "#EBCB8B",
          "font_weight": 700
        },
        "keyword.comment.warn.text": {
          "color": "#ECEFF4"
        },
        "string.comment.note": {
          "color": "#2E3440",
          "background_color": "#88C0D0",
          "font_weight": 700
        },
        "string.comment.note.text": {
          "color": "#ECEFF4"
        },
        "string.comment.info": {
          "color": "#2E3440",
          "background_color": "#81A1C1",
          "font_weight": 700
        },
        "string.comment.info.text": {
          "color": "#ECEFF4"
        }
      }
    }
  },

  "format_on_save": "off",
  "ui_font_size": 16,
  "ui_font_family": "GeistMono Nerd Font Mono",
  "ui_font_weight": 300,
  "buffer_font_family": "SHCode JP Zen Haku",
  "buffer_font_weight": 300,
  "buffer_font_size": 13.8,
  "tab_size": 2,
  "colorize_brackets": false,
  "show_whitespaces": "selection",
  "whitespace_map": {
    "space": "•",
    "tab": "→"
  },
  "cursor_shape": "block",
  "scroll_beyond_last_line": "off",
  "scroll_sensitivity": 1.2,
  "fast_scroll_sensitivity": 8.0,
  "extend_comment_on_newline": false,
  "soft_wrap": "editor_width",
  "line_indicator_format": "long",
  "sticky_scroll": {
    "enabled": false
  },
  "scrollbar": {
    "axes": {
      "horizontal": false,
      "vertical": true
    }
  },
  "title_bar": {
    "show_branch_icon": false,
    "show_branch_name": true,
    "show_project_items": true,
    "show_onboarding_banner": true,
    "show_user_picture": true,
    "show_sign_in": true,
    "show_menus": true
  },
  "minimap": {
    "show": "never",
    "thumb": "always",
    "thumb_border": "left_open",
    "current_line_highlight": null
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": true,
    "agent_review": true,
    "code_actions": true
  },
  "project_panel": {
    "button": true,
    "default_width": 320,
    "dock": "left",
    "entry_spacing": "standard",
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_size": 14,
    "auto_reveal_entries": true,
    "auto_fold_dirs": true,
    "drag_and_drop": true,
    "scrollbar": {
      "show": "never"
    },
    "sticky_scroll": false,
    "show_diagnostics": "all",
    "indent_guides": {
      "show": "never"
    },
    "hide_root": true,
    "starts_open": true
  },
  "collaboration_panel": {
    "button": true,
    "dock": "left",
    "default_width": 320
  },
  "git_panel": {
    "button": true,
    "dock": "left",
    "default_width": 320,
    "status_style": "icon",
    "fallback_branch_name": "main",
    "sort_by_path": false,
    "collapse_untracked_diff": false,
    "scrollbar": {
      "show": "never"
    }
  },
  "outline_panel": {
    "button": true,
    "default_width": 320,
    "dock": "left",
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_size": 14,
    "auto_reveal_entries": true,
    "auto_fold_dirs": true,
    "indent_guides": {
      "show": "always"
    },
    "scrollbar": {
      "show": "never"
    }
  },
  "search": {
    "button": false,
    "whole_word": false,
    "case_sensitive": false,
    "include_ignored": false,
    "regex": false,
    "center_on_match": false
  },
  "tabs": {
    "close_position": "left",
    "file_icons": false,
    "git_status": true,
    "activate_on_close": "history",
    "show_close_button": "hover",
    "show_diagnostics": "errors"
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Nord-Custom"
  },
  "indent_guides": {
    "enabled": true,
    "line_width": 1,
    "active_line_width": 1,
    "coloring": "fixed",
    "background_coloring": "disabled"
  },
  "terminal": {
    "cursor_shape": "block",
    "blinking": "on",
    "font_family": "GeistMono Nerd Font Mono",
    "font_weight": 300,
    "line_height": {
      "custom": 1.3
    },
    "shell": {
      "with_arguments": {
        "program": "/run/current-system/sw/bin/zsh",
        "args": ["-l"]
      }
    },
    "toolbar": {
      "breadcrumbs": false
    }
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": false
    },
    "branch_picker": {
      "show_author_name": true
    },
    "hunk_style": "staged_hollow"
  },
  "languages": {
    "Markdown": {
      "remove_trailing_whitespace_on_save": false
    },
    "Nix": {
      "language_servers": ["nixd"]
    },
    "Lua": {
      "tab_size": 2,
      "hard_tabs": false,
      "auto_indent": "none"
    }
  },
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  }
}
