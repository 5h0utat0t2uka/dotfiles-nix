[user]
  name = {{ .git.name }}
  email = {{ .git.email }}

[core]
  editor = vim
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  side-by-side = true
  line-numbers = true
  syntax-theme = Nord
  file-style = bold
  file-decoration-style = none

[merge]
  conflictstyle = diff3

[diff]
  colorMoved = default

[init]
  defaultBranch = main

[push]
  autoSetupRemote = true

[url "git@github.com:"]
  insteadOf = https://github.com/

[ghq]
  user = {{ .ghq.user }}
  root = {{ .ghq.root }}
