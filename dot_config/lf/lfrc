set drawbox true
set roundbox false
set icons
set hidden true
set preview true
set previewer ~/.config/lf/pv.sh
set borderfmt "\033[90m"

cmd edit-on-parent ${{
  if [ -n "$LF_TMUX_PARENT_PANE" ]; then
    tmux send-keys -t "$LF_TMUX_PARENT_PANE" "nvim $(printf '%q' "$f")" Enter
    lf -remote "send $id quit"
  else
    nvim "$f"
  fi
}}

map e edit-on-parent

cmd open ${{
  case "$(file --mime-type -Lb "$f")" in
    text/*|application/json|application/xml|application/javascript)
      if [ -n "$LF_TMUX_PARENT_PANE" ]; then
        tmux send-keys -t "$LF_TMUX_PARENT_PANE" "nvim $(printf '%q' "$f")" Enter
        lf -remote "send $id quit"
      else
        nvim "$f"
      fi
      ;;
    *)
      "$OPENER" "$f"
      ;;
  esac
}}
