set dotenv-load := false
set shell := ["bash", "-euo", "pipefail", "-c"]

flake := "{{ .chezmoi.sourceDir }}/nix"
hostname := `scutil --get LocalHostName 2>/dev/null`

check:
  nix flake check {{ "{{flake}}" }}

build:
  nix build -L {{ "{{flake}}" }}#darwinConfigurations.{{ "{{hostname}}" }}.system --no-link

switch:
  sudo darwin-rebuild switch --flake {{ "{{flake}}" }}#{{ "{{hostname}}" }}

# 引数に渡されたパッケージのインストール済みのバージョンと、現在の最新バージョンと比較
check-pkg pkg:
  cd {{ "{{flake}}" }} && \
    current="$(nix eval --raw .#darwinConfigurations.{{ "{{hostname}}" }}.pkgs.{{ "{{pkg}}" }}.version)" && \
    latest="$(nix eval --raw github:NixOS/nixpkgs/nixos-unstable#{{ "{{pkg}}" }}.version)" && \
    printf '%s: current=%s latest=%s\n' "{{ "{{pkg}}" }}" "$current" "$latest"

# nixpkgs のみ最新バージョンに更新
update-pkg:
  cd {{ "{{flake}}" }} && nix flake update nixpkgs

# nixpkgs, darwin, home-manager など全てを最新バージョンに更新
update-all:
  cd {{ "{{flake}}" }} && nix flake update

gc:
  nix-collect-garbage -d
