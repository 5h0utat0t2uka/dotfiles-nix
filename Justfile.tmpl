set dotenv-load := false
set shell := ["bash", "-euo", "pipefail", "-c"]

flake := "{{ .chezmoi.sourceDir }}/nix"
hostname := `scutil --get LocalHostName 2>/dev/null`

# 1. 最新の nixpkgs-unstable に差し替えてビルド検証
update-check:
  nix build -L \
    --override-input nixpkgs github:NixOS/nixpkgs/nixpkgs-unstable \
    {{ "{{flake}}" }}#darwinConfigurations.{{ "{{hostname}}" }}.system \
    --no-link

# 2. flake.lock の nixpkgs を最新バージョンに更新
update-pkg:
  cd {{ "{{flake}}" }} && nix flake update nixpkgs

# 3. flake.lock の全ての input を最新バージョンに更新
update-all:
  cd {{ "{{flake}}" }} && nix flake update

# 4. 現在の flake.lock で flake の評価と検証
check:
  nix flake check {{ "{{flake}}" }}

# 5. 現在の flake.lock のビルドを検証
check-build:
  nix build -L {{ "{{flake}}" }}#darwinConfigurations.{{ "{{hostname}}" }}.system --no-link

# 6. 現在の flake.lock でビルドと反映
switch:
  sudo darwin-rebuild switch --flake {{ "{{flake}}" }}#{{ "{{hostname}}" }}

gc:
  nix-collect-garbage -d
