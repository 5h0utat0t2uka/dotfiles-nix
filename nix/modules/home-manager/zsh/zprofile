# ~/.config/zsh/.zprofile
# Purpose:
# - Initialize Homebrew env via `brew shellenv`
# - Enforce PATH order: Nix first, Homebrew later (cask-only policy)
#
# Note: Static PATH additions (/etc/profiles/per-user/$USER/bin,
# /run/current-system/sw/bin, $HOME/.local/bin) are handled by
# nix-darwin and home-manager automatically.

typeset -U path

# NIX_PROFILE_PREFIX is static because zshPluginLinks places plugins
# under /etc/profiles/per-user/$USER/share/zsh/plugins.
export NIX_PROFILE_PREFIX="/etc/profiles/per-user/$USER"

# Homebrew environment
if [[ -x /run/current-system/sw/bin/brew ]]; then
  eval "$(/run/current-system/sw/bin/brew shellenv)"
elif [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# --- Final PATH order fix (prefer Nix, keep Homebrew later) ---

# Put Nix profile first
if [[ -d "${NIX_PROFILE_PREFIX}/bin" ]]; then
  path=("${path[@]:#${NIX_PROFILE_PREFIX}/bin}")
  path=("${NIX_PROFILE_PREFIX}/bin" $path)
fi

# Push Homebrew behind Nix (brew is cask-only in this setup)
path=("${path[@]:#/opt/homebrew/bin}")
path=("${path[@]:#/opt/homebrew/sbin}")
path+=("/opt/homebrew/bin" "/opt/homebrew/sbin")

typeset -U path
export PATH
